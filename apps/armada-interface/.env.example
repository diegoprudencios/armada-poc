# Copy to `.env.development` (gitignored) and restart Vite: cp .env.example .env.development
# Without a copy, VITE_NETWORK defaults to local (fake Anvil + auto mock balance).
#
# Local fake money: VITE_NETWORK=local (+ Anvil: `npm run chains` from armada-poc root).
# Production/preview: VITE_NETWORK=sepolia (set in netlify.toml — do not override for deploy).
#
# One-time: npm run prepare:artifacts
# Relayer local: npm run relayer:local (armada-poc root, after `npm run setup`)
# Relayer sepolia fees-only: npm run relayer:sepolia-dev

VITE_NETWORK=local
VITE_RELAYER_URL=http://localhost:3001
VITE_DEV_MOCK_BALANCE=true

# Sepolia overrides (only when VITE_NETWORK=sepolia)
# VITE_SEPOLIA_RPC=
# VITE_BASE_SEPOLIA_RPC=
# VITE_ARB_SEPOLIA_RPC=
# VITE_WALLETCONNECT_PROJECT_ID=
